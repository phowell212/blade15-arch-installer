#!/usr/bin/env bash
set -u -o pipefail

GPU_LIB=${GPU_LIB:-/usr/local/lib/blade-firstboot/gpu.sh}
GPU_GATE_MARKER=${GPU_GATE_MARKER:-/var/lib/blade-installer/gpu-gate-passed}
GPU_GATE_LOG=${GPU_GATE_LOG:-/var/log/blade-gpu-firstboot.log}
TTY_PATH=${TTY_PATH:-/dev/tty1}
SYSTEMCTL_BIN=${SYSTEMCTL_BIN:-systemctl}
REBOOT_BIN=${REBOOT_BIN:-reboot}
marker_tmp=${GPU_GATE_MARKER}.tmp.$$

# shellcheck source=/dev/null
source "$GPU_LIB"

write_recovery_instructions() {
  {
    printf 'Blade GPU validation failed; GNOME remains disabled.\n'
    printf 'Diagnostics: %s\n' "$GPU_GATE_LOG"
    printf 'Review with: journalctl -u blade-firstboot-gpu.service\n'
    printf 'Boot the Intel-only recovery or text recovery entry if needed.\n'
    printf 'After repairs: sudo systemctl start blade-firstboot-gpu.service\n'
  } >"$TTY_PATH" 2>/dev/null || true
}

prevent_automatic_retry() {
  if ! "$SYSTEMCTL_BIN" disable blade-firstboot-gpu.service >>"$GPU_GATE_LOG" 2>&1; then
    printf 'Warning: unable to disable automatic GPU gate retry\n' >>"$GPU_GATE_LOG"
  fi
}

mkdir -p -- "${GPU_GATE_LOG%/*}"
printf 'Blade first-boot GPU gate\n' >"$GPU_GATE_LOG"

gpu_gate >>"$GPU_GATE_LOG" 2>&1
gate_status=$?
if ((gate_status != 0)); then
  prevent_automatic_retry
  write_recovery_instructions
  printf 'GPU validation failed; see %s\n' "$GPU_GATE_LOG" >&2
  exit "$gate_status"
fi

if ! mkdir -p -- "${GPU_GATE_MARKER%/*}" 2>>"$GPU_GATE_LOG" ||
  ! printf 'passed\n' >"$marker_tmp" 2>>"$GPU_GATE_LOG"; then
  rm -f -- "$marker_tmp"
  printf 'GPU gate failed: unable to prepare success marker\n' >>"$GPU_GATE_LOG"
  prevent_automatic_retry
  write_recovery_instructions
  exit 1
fi

if ! "$SYSTEMCTL_BIN" enable gdm.service >>"$GPU_GATE_LOG" 2>&1; then
  rm -f -- "$marker_tmp"
  printf 'GPU gate failed: unable to enable gdm.service\n' >>"$GPU_GATE_LOG"
  prevent_automatic_retry
  write_recovery_instructions
  exit 1
fi
if ! "$SYSTEMCTL_BIN" set-default graphical.target >>"$GPU_GATE_LOG" 2>&1; then
  rm -f -- "$marker_tmp"
  "$SYSTEMCTL_BIN" disable gdm.service >>"$GPU_GATE_LOG" 2>&1 || true
  printf 'GPU gate failed: unable to set graphical.target as default\n' >>"$GPU_GATE_LOG"
  prevent_automatic_retry
  write_recovery_instructions
  exit 1
fi
if ! "$SYSTEMCTL_BIN" disable blade-firstboot-gpu.service >>"$GPU_GATE_LOG" 2>&1; then
  rm -f -- "$marker_tmp"
  "$SYSTEMCTL_BIN" set-default multi-user.target >>"$GPU_GATE_LOG" 2>&1 || true
  "$SYSTEMCTL_BIN" disable gdm.service >>"$GPU_GATE_LOG" 2>&1 || true
  printf 'GPU gate failed: unable to disable first-boot GPU gate\n' >>"$GPU_GATE_LOG"
  write_recovery_instructions
  exit 1
fi

if ! mv -f -- "$marker_tmp" "$GPU_GATE_MARKER" 2>>"$GPU_GATE_LOG"; then
  "$SYSTEMCTL_BIN" enable blade-firstboot-gpu.service >>"$GPU_GATE_LOG" 2>&1 || true
  "$SYSTEMCTL_BIN" set-default multi-user.target >>"$GPU_GATE_LOG" 2>&1 || true
  "$SYSTEMCTL_BIN" disable gdm.service >>"$GPU_GATE_LOG" 2>&1 || true
  printf 'GPU gate failed: unable to write success marker\n' >>"$GPU_GATE_LOG"
  write_recovery_instructions
  exit 1
fi
"$REBOOT_BIN"
